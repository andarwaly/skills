{
  "schemaVersion": "0.1.0",
  "name": "Article with AI Context",
  "behavior": "create",
  "noteContentFormat": "# {{title}}\n\n## AI Summary\n\n{{\"Summarize the key arguments in 3 bullet points\"}}\n\n## Content\n\n{{content}}",
  "noteNameFormat": "{{title|safe_name}}",
  "path": "Clippings",
  "triggers": [
    "https://example.com/"
  ],
  "context": "{{selectorHtml:main|markdown|slice:0,5000|trim}}",
  "properties": [
    { "name": "source", "value": "{{url}}", "type": "text" },
    { "name": "author", "value": "{{author|wikilink}}", "type": "multitext" },
    { "name": "published", "value": "{{published|date:\"YYYY-MM-DD\"}}", "type": "date" },
    { "name": "summary", "value": "{{\"extract a one-sentence summary\"}}", "type": "text" },
    { "name": "tags", "value": "to-read, clippings", "type": "multitext" }
  ]
}
